<section class="image-text" style="padding: 64px 20px;">
  <div class="container" style="display: flex; align-items: center; gap: 48px; flex-direction: {% if section.props.imagePosition == 'right' %}row-reverse{% else %}row{% endif %};">
    <div style="flex: 1; min-height: 400px; background: var(--color-background-alt); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
      {% if section.props.image %}
      <img src="{{ section.props.image }}" alt="" style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;">
      {% else %}
      <span style="color: var(--color-text-light);">Image Placeholder</span>
      {% endif %}
    </div>
    <div style="flex: 1;">
      {% if section.props.heading %}
      <h2 style="font-size: 36px; margin-bottom: 24px;">{{ section.props.heading }}</h2>
      {% endif %}
      {% if section.props.content %}
      <p style="font-size: 18px; color: var(--color-text-light); margin-bottom: 24px;">{{ section.props.content }}</p>
      {% endif %}
      {% if section.props.ctaText %}
      <a href="{{ section.props.ctaLink }}" style="display: inline-block; background: var(--color-primary); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600;">{{ section.props.ctaText }}</a>
      {% endif %}
    </div>
  </div>
</section>